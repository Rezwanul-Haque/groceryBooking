PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5435
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=grocery_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
